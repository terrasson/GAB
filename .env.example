# ╔══════════════════════════════════════════════╗
# ║   GAB — Grand Assistant de Bureau            ║
# ║   Copiez ce fichier en .env et remplissez    ║
# ╚══════════════════════════════════════════════╝

# ── LLM Hermes / Ollama ───────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
HERMES_MODEL=nous-hermes2
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ── Telegram ──────────────────────────────────────────────────────────────────
# Obtenez votre token via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=

# ── WhatsApp (Meta Business Cloud API) ───────────────────────────────────────
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WA_TOKEN=          # Token d'accès permanent (Meta for Developers)
WA_PHONE_ID=       # ID du numéro de téléphone WhatsApp Business
WA_VERIFY_TOKEN=gab_secret   # Token de vérification webhook (choisissez une valeur secrète)

# ── Discord ───────────────────────────────────────────────────────────────────
# https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# ── Admins (IDs séparés par des virgules) ────────────────────────────────────
# Format : ID Telegram, Discord, ou numéro WhatsApp
# Ex : ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ── Serveur API interne (webhooks + healthcheck) ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
