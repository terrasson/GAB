# ╔══════════════════════════════════════════════╗
# ║   GAB — Grand Assistant de Bureau            ║
# ║   Copiez ce fichier en .env et remplissez    ║
# ╚══════════════════════════════════════════════╝

# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider : ollama | openai | deepseek | mistral | groq | together | anthropic
LLM_PROVIDER=ollama

# Modèle (dépend du provider)
#   ollama    : qwen3:8b, llama3.1:8b, mistral, nous-hermes2, …
#   openai    : gpt-4o-mini, gpt-4o, o1-mini, …
#   deepseek  : deepseek-chat, deepseek-reasoner
#   mistral   : mistral-large-latest, mistral-small-latest
#   groq      : llama-3.1-70b-versatile, mixtral-8x7b-32768
#   anthropic : claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
LLM_MODEL=qwen3:8b

# URL de l'API (laisser vide pour utiliser le défaut du provider)
#   ollama    par défaut : http://localhost:11434
#   openai    par défaut : https://api.openai.com
#   deepseek  par défaut : https://api.deepseek.com
#   anthropic par défaut : https://api.anthropic.com
LLM_BASE_URL=

# Clé API (vide pour Ollama, requise pour les providers cloud)
LLM_API_KEY=

# Génération
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ── Telegram ──────────────────────────────────────────────────────────────────
# Obtenez votre token via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=

# ── WhatsApp (Meta Business Cloud API) ───────────────────────────────────────
# https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
WA_TOKEN=
WA_PHONE_ID=
WA_VERIFY_TOKEN=gab_secret

# ── Discord ───────────────────────────────────────────────────────────────────
# https://discord.com/developers/applications → Bot → Token
DISCORD_TOKEN=

# ── Admins (IDs séparés par des virgules) ────────────────────────────────────
# Ex : ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# ── Whitelist d'accès (recommandé en prod pour ne pas faire cramer ses crédits LLM) ──
# Si les DEUX listes sont vides → mode permissif (tout le monde peut parler à GAB).
# Si AU MOINS UNE est remplie → mode strict : seuls les users/groupes listés
# auront le droit d'invoquer le LLM.
#
# ALLOWED_USERS : liste blanche d'utilisateurs (DM ou groupe), séparés par virgule.
# Format : <user_id> ou <platform>:<user_id>
# Exemple : ALLOWED_USERS=6232026739,telegram:8353970196
ALLOWED_USERS=

# ALLOWED_GROUPS : liste blanche de groupes (chat_id Telegram, etc.).
# Tous les membres d'un groupe whitelisté peuvent utiliser GAB dans ce groupe.
# Exemple : ALLOWED_GROUPS=-1001234567890,-1009876543210
ALLOWED_GROUPS=

# ── Serveur API interne (webhooks + healthcheck) ──────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
